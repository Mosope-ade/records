// ShopSync PWA - Prisma Schema
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Debt Ledger ─────────────────────────────────────────────────────────────

model DebtEntry {
  id          String   @id @default(cuid())
  customerName String  @map("customer_name")
  totalDebt   Decimal  @map("total_debt")   @db.Decimal(12, 2)
  amountPaid  Decimal  @map("amount_paid")  @db.Decimal(12, 2) @default(0)
  balance     Decimal  @map("balance")      @db.Decimal(12, 2)
  notes       String?
  createdBy   String   @map("created_by")   // neon_auth user id
  createdAt   DateTime @map("created_at")   @default(now())
  updatedAt   DateTime @map("updated_at")   @updatedAt

  payments    Payment[]

  @@index([customerName])
  @@index([createdAt])
  @@map("debt_entries")
}

model Payment {
  id          String    @id @default(cuid())
  debtId      String    @map("debt_id")
  amount      Decimal   @db.Decimal(12, 2)
  paidBy      String    @map("paid_by")     // neon_auth user id
  note        String?
  paidAt      DateTime  @map("paid_at")    @default(now())

  debt        DebtEntry @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
  @@map("payments")
}

// ─── Inventory ───────────────────────────────────────────────────────────────

enum StockStatus {
  LOW_STOCK
  OUT_OF_STOCK
  RESTOCKED
}

model InventoryItem {
  id          String      @id @default(cuid())
  itemName    String      @map("item_name")
  status      StockStatus @default(LOW_STOCK)
  quantity    Int         @default(0)          // stock quantity tracker
  reportedBy  String      @map("reported_by")  // neon_auth user id
  createdAt   DateTime    @map("created_at")   @default(now())
  updatedAt   DateTime    @map("updated_at")   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("inventory_items")
}

// ─── Products / Price List ──────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String   @unique
  priceUnit   Decimal  @map("price_unit") @db.Decimal(12, 2)
  unitName    String?  @map("unit_name")  @default("pcs")       // e.g. "unit", "bottle"
  priceBulk   Decimal  @map("price_bulk") @db.Decimal(12, 2)
  bulkName    String?  @map("bulk_name")  @default("carton")    // e.g. "carton", "pack"
  createdBy   String   @map("created_by")
  createdAt   DateTime @map("created_at") @default(now())
  updatedAt   DateTime @map("updated_at") @updatedAt

  @@index([name])
  @@map("products")
}

// ─── Push Subscriptions ──────────────────────────────────────────────────────

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  endpoint    String   @unique
  p256dh      String
  auth        String
  createdAt   DateTime @map("created_at") @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

